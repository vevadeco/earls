# Earl's Landscaping - Environment Variables Template
# Copy this to .env and fill in your actual values
# This file is safe to commit (no real secrets)

# ============================================
# DATABASE (MongoDB Atlas)
# ============================================
# Get your connection string from:
# https://www.mongodb.com/atlas/database
# Create a free cluster → Connect → Drivers → Python → copy string
MONGO_URL="mongodb+srv://username:password@cluster.mongodb.net/earls_landscaping?retryWrites=true&w=majority"
DB_NAME="earls_landscaping"

# ============================================
# EMAIL (Resend)
# ============================================
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SENDER_EMAIL="onboarding@resend.dev"
NOTIFICATION_EMAILS="info@earlslandscaping.ca, your-email@example.com"

# ============================================
# SECURITY
# ============================================
# Generate a random string (32+ characters):
# Open terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"

# ============================================
# ADMIN AUTH
# ============================================
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="your-secure-admin-password"

# ============================================
# CORS / FRONTEND
# ============================================
# Your Vercel domain after deployment
CORS_ORIGINS="https://your-app.vercel.app,http://localhost:3000"

# ============================================
# OPTIONAL: Local Development
# ============================================
# REACT_APP_BACKEND_URL="http://localhost:8001"
# For production, this should be: /api
